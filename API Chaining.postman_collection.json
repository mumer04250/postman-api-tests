  "item": [
    {
      "name": "CreateUser",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// dynamic email generate\r",
              "let email = pm.variables.replaceIn(\"{{$randomEmail}}\");\r",
              "// save to environment\r",
              "pm.environment.set(\"email\", email);\r",
              "let username = pm.variables.replaceIn(\"{{$randomFirstName}}\");\r",
              "\r",
              "pm.environment.set(\"username\", username);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "\r",
              "    const res=pm.response.json()\r",
              "    pm.environment.set('user_id',res.id)\r",
              "\r",
              "    pm.test('Check Status',function(){\r",
              "        \r",
              "        pm.response.to.have.status(201)\r",
              "    })\r",
              "    pm.test('Execution Time Check',function(){\r",
              "        pm.expect(pm.response.responseTime).to.have.below(2000)\r",
              "    })\r",
              "    pm.test('Id exist check',function(){\r",
              "        pm.expect(res.id).to.exist\r",
              "    })\r",
              "    pm.execution.setNextRequest('Get User Details')\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"{{username}}\",\r\n  \"gender\": \"male\",\r\n  \"email\": \"{{email}}\",\r\n  \"status\": \"active\"\r\n}",
          "options": {
